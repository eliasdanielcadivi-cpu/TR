#!/bin/bash
# ═══════════════════════════════════════════════════════════════════════════════
# TR INVESTIGADOR - Herramienta de Inteligencia y Exploración
# ═══════════════════════════════════════════════════════════════════════════════
# Parte del módulo 'investigador' de TRON.
# Este wrapper garantiza que el módulo se ejecute en su entorno virtual (uv).
# ═══════════════════════════════════════════════════════════════════════════════

# 1. Determinar raíz del proyecto
PROJECT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)

# 2. Ejecutar script original usando 'uv run'
# --project asegura que busque el pyproject.toml en la raíz del proyecto
exec uv run --project "$PROJECT_DIR" python "$PROJECT_DIR/bin/tr-investigador-python" "$@"
