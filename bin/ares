#!/usr/bin/env python3
"""ARES: Terminal Remote Operations Nexus - Launcher.

Este script permite invocar ARES desde cualquier ubicación.
"""

import os
import sys
from pathlib import Path

# Resolver ruta absoluta del directorio del proyecto
BIN_DIR = Path(__file__).parent.resolve()
PROJECT_DIR = BIN_DIR.parent.resolve()

# Añadir al path para imports
sys.path.insert(0, str(PROJECT_DIR))

# Ejecutar main.py
main_py = PROJECT_DIR / "src" / "main.py"

if __name__ == "__main__":
    import runpy
    runpy.run_path(str(main_py), run_name="__main__")
